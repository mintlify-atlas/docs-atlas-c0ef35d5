  "keyFeatures": [
    "Kotlin Multiplatform architecture for iOS and Android",
    "Compose Multiplatform for shared UI components",
    "Firebase authentication with Google and Apple Sign-In",
    "AI-powered icebreaker generation using Gemini API",
    "RevenueCat subscription management",
    "Koin dependency injection",
    "Room database for local data persistence",
    "Ktor networking client"
  ],
  "publicApiSurface": [
    "initKoin() - Initialize dependency injection",
    "AuthRepository - Authentication management",
    "AuthViewModel - Authentication UI state",
    "NativeAuthHandler - Platform-specific auth handling",
    "IcebreakerRepository - Icebreaker generation",
    "GenerateIcebreakerUseCase - Generate AI conversation starters",
    "RollDiceUseCase - Random icebreaker selection",
    "SubscriptionRepository - Subscription state management",
    "RevenueCatService - In-app purchase integration",
    "OnboardingRepository - User onboarding flow",
    "SuccessRepository - User success tracking",
    "AuthBottomSheet - Composable auth UI",
    "HomeScreen - Main screen composable",
    "BuildKonfig - Environment configuration"
  ]
}
